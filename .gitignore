# Git Ignore rules for full-stack Inventory & Order Management System

# Local environment configuration
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Python backend files
backend/.venv/
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/inventory.db

# React frontend files
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.eslintcache

# Logs and system files
*.log
.DS_Store
Thumbs.db
.idea/
.vscode/
